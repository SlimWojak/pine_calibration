//@version=6
// =============================================================================
// htf_map_v1 — pine_calibration sandbox
// =============================================================================
// Visual calibration of the en1gma HTF MAP algorithm on FX:EURUSD Daily.
// Source of truth: en1gma/console/detection/locked_baseline.yaml + vLOCK.yaml.
// CODE WINS in conflicts (per en1gma/docs/canonical/DETECTION_PRIMITIVES_INDEX.md).
//
// Calibration slice (Mar 2 fixture):
//   [x] Daily swing_points    (fractal-N=2 + 15-pip height filter)
//   [x] Daily displacement    (ATR + body + close-gate + decisive_override + cluster_2)
//   [x] Daily mss             (swing-break with displacement gate + swing consumption)
//   [x] Map Direction state + Delivery Failure event
//   [x] 3-mode direction-flip toggle (DF / REPLACEMENT / HYBRID)
//   [x] Pivotal date markers + state-readout table
//
// Fixture: fixtures/2026-03-02_bearish_flip.md
// =============================================================================

indicator("HTF MAP V1 — calibration sandbox", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// --- locked params (Daily) — verbatim from en1gma locked_baseline.yaml ---
SWING_N_DAILY              = 2
SWING_HEIGHT_FILTER_PIPS_D = 15.0

DISP_HTF_ATR_MULT          = 1.50
DISP_HTF_BODY_RATIO        = 0.65
DISP_HTF_CLOSE_GATE        = 0.25
DISP_DECISIVE_BODY_MIN     = 0.75
DISP_DECISIVE_CLOSE_MAX    = 0.10
DISP_NET_EFFICIENCY_MIN    = 0.65

MSS_HTF_CONFIRM_WINDOW_BARS = 1
PIP_VALUE = 0.0001

// --- inputs ---
i_flip_mode         = input.string("C_HYBRID", "Direction-flip rule mode", options=["A_DELIVERY_FAILURE", "B_REPLACEMENT", "C_HYBRID"], group="Calibration")
i_show_swings       = input.bool(true, "Show swing points",        group="Debug overlays")
i_show_displacement = input.bool(true, "Show displacement",        group="Debug overlays")
i_show_mss          = input.bool(true, "Show MSS",                 group="Debug overlays")
i_show_direction    = input.bool(true, "Show Map Direction tint",  group="Map overlays")
i_show_df_events    = input.bool(true, "Show DF events",           group="Map overlays")
i_show_pivotal      = input.bool(true, "Show pivotal date markers", group="Map overlays")
i_show_table        = input.bool(true, "Show state readout table",  group="Map overlays")
i_atr_length        = input.int(14,    "ATR length",               group="Calibration", minval=1)

// =============================================================================
// swing_points (Daily)
// =============================================================================
ph_raw = ta.pivothigh(SWING_N_DAILY, SWING_N_DAILY)
pl_raw = ta.pivotlow(SWING_N_DAILY, SWING_N_DAILY)

f_max_neighbor_high(int N) =>
    float m = na
    for i = 0 to N * 2
        if i != N
            v = high[i]
            m := na(m) ? v : math.max(m, v)
    m

f_min_neighbor_low(int N) =>
    float m = na
    for i = 0 to N * 2
        if i != N
            v = low[i]
            m := na(m) ? v : math.min(m, v)
    m

ph_height_pips = not na(ph_raw) ? (ph_raw - f_max_neighbor_high(SWING_N_DAILY)) / PIP_VALUE : na
pl_height_pips = not na(pl_raw) ? (f_min_neighbor_low(SWING_N_DAILY) - pl_raw) / PIP_VALUE : na

ph_valid = not na(ph_raw) and ph_height_pips >= SWING_HEIGHT_FILTER_PIPS_D
pl_valid = not na(pl_raw) and pl_height_pips >= SWING_HEIGHT_FILTER_PIPS_D

plot_ph = (ph_valid and i_show_swings) ? ph_raw : na
plot_pl = (pl_valid and i_show_swings) ? pl_raw : na

plot(plot_ph, title="Daily SH", style=plot.style_cross, linewidth=3, color=color.red,   offset=-SWING_N_DAILY)
plot(plot_pl, title="Daily SL", style=plot.style_cross, linewidth=3, color=color.green, offset=-SWING_N_DAILY)

// =============================================================================
// displacement (Daily)
// =============================================================================
candle_range = high - low
candle_body  = math.abs(close - open)
body_ratio   = candle_range > 0 ? candle_body / candle_range : 0.0
atr_val      = ta.atr(i_atr_length)
atr_ratio    = atr_val > 0 ? candle_range / atr_val : 0.0

is_bull_bar  = close > open
is_bear_bar  = close < open
close_loc    = candle_range > 0 ? (close - low) / candle_range : 0.5

decisive_bull = is_bull_bar and body_ratio >= DISP_DECISIVE_BODY_MIN and close_loc >= (1 - DISP_DECISIVE_CLOSE_MAX)
decisive_bear = is_bear_bar and body_ratio >= DISP_DECISIVE_BODY_MIN and close_loc <= DISP_DECISIVE_CLOSE_MAX

single_atr_bull = is_bull_bar and atr_ratio >= DISP_HTF_ATR_MULT and body_ratio >= DISP_HTF_BODY_RATIO and close_loc >= (1 - DISP_HTF_CLOSE_GATE)
single_atr_bear = is_bear_bar and atr_ratio >= DISP_HTF_ATR_MULT and body_ratio >= DISP_HTF_BODY_RATIO and close_loc <= DISP_HTF_CLOSE_GATE

two_bar_high   = math.max(high, high[1])
two_bar_low    = math.min(low, low[1])
two_bar_range  = two_bar_high - two_bar_low
two_bar_net    = math.abs(close - open[1])
two_bar_eff    = two_bar_range > 0 ? two_bar_net / two_bar_range : 0.0
two_bar_atr_r  = atr_val > 0 ? two_bar_range / atr_val : 0.0
same_dir_bull  = close > open and close[1] > open[1]
same_dir_bear  = close < open and close[1] < open[1]

single_path_bull = decisive_bull or single_atr_bull
single_path_bear = decisive_bear or single_atr_bear
prior_single_bull = decisive_bull[1] or single_atr_bull[1]
prior_single_bear = decisive_bear[1] or single_atr_bear[1]

cluster_bull = same_dir_bull and two_bar_atr_r >= DISP_HTF_ATR_MULT and two_bar_eff >= DISP_NET_EFFICIENCY_MIN and not single_path_bull and not prior_single_bull
cluster_bear = same_dir_bear and two_bar_atr_r >= DISP_HTF_ATR_MULT and two_bar_eff >= DISP_NET_EFFICIENCY_MIN and not single_path_bear and not prior_single_bear

qg_strong = decisive_bull or decisive_bear
qg_valid  = (not qg_strong) and (single_atr_bull or single_atr_bear or cluster_bull or cluster_bear)

disp_dir  = (decisive_bull or single_atr_bull or cluster_bull) ? 1 : (decisive_bear or single_atr_bear or cluster_bear) ? -1 : 0
quality_grade = qg_strong ? "STRONG" : qg_valid ? "VALID" : ""

plotshape(i_show_displacement and qg_strong and disp_dir > 0, title="Disp STRONG bull", style=shape.diamond, location=location.belowbar, color=color.yellow, size=size.tiny)
plotshape(i_show_displacement and qg_strong and disp_dir < 0, title="Disp STRONG bear", style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.tiny)
plotshape(i_show_displacement and qg_valid  and disp_dir > 0, title="Disp VALID bull",  style=shape.circle,  location=location.belowbar, color=color.aqua,   size=size.tiny)
plotshape(i_show_displacement and qg_valid  and disp_dir < 0, title="Disp VALID bear",  style=shape.circle,  location=location.abovebar, color=color.aqua,   size=size.tiny)

// =============================================================================
// mss (Daily) — consumes displacement + swings, emits MSS up/dn events
// =============================================================================
var array<float> unc_sh_price = array.new<float>()
var array<int>   unc_sh_bar   = array.new<int>()
var array<float> unc_sl_price = array.new<float>()
var array<int>   unc_sl_bar   = array.new<int>()

if ph_valid
    array.push(unc_sh_price, ph_raw)
    array.push(unc_sh_bar,   bar_index - SWING_N_DAILY)
if pl_valid
    array.push(unc_sl_price, pl_raw)
    array.push(unc_sl_bar,   bar_index - SWING_N_DAILY)

disp_bull_now  = (qg_strong or qg_valid) and disp_dir > 0
disp_bear_now  = (qg_strong or qg_valid) and disp_dir < 0
mss_bull_disp_ok = disp_bull_now or disp_bull_now[1]
mss_bear_disp_ok = disp_bear_now or disp_bear_now[1]

bool  mss_bull_fired  = false
bool  mss_bear_fired  = false

if mss_bull_disp_ok
    int i = 0
    while i < array.size(unc_sh_price)
        sh = array.get(unc_sh_price, i)
        if close > sh
            sh_bar_idx = array.get(unc_sh_bar, i)
            mss_bull_fired := true
            if i_show_mss
                line.new(chart.point.from_index(sh_bar_idx, sh), chart.point.from_index(bar_index, sh), color=color.new(color.lime, 0), width=2, extend=extend.none)
                label.new(chart.point.from_index(bar_index, high), text="MSS up", style=label.style_label_down, color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
            array.remove(unc_sh_price, i)
            array.remove(unc_sh_bar,   i)
        else
            i := i + 1

if mss_bear_disp_ok
    int j = 0
    while j < array.size(unc_sl_price)
        sl = array.get(unc_sl_price, j)
        if close < sl
            sl_bar_idx = array.get(unc_sl_bar, j)
            mss_bear_fired := true
            if i_show_mss
                line.new(chart.point.from_index(sl_bar_idx, sl), chart.point.from_index(bar_index, sl), color=color.new(color.red, 0), width=2, extend=extend.none)
                label.new(chart.point.from_index(bar_index, low), text="MSS dn", style=label.style_label_up, color=color.new(color.red, 0), textcolor=color.white, size=size.small)
            array.remove(unc_sl_price, j)
            array.remove(unc_sl_bar,   j)
        else
            j := j + 1

// =============================================================================
// MAP STATE — direction, DF events, last-event tracking for table
// =============================================================================
var int    map_direction   = 0
var int    range_birth_bar = na
var int    last_mss_time   = 0
var string last_mss_kind   = "-"
var int    last_df_time    = 0
var string last_df_kind    = "-"

if mss_bull_fired
    opposite = map_direction == -1
    fire_df  = opposite and (i_flip_mode == "A_DELIVERY_FAILURE" or i_flip_mode == "C_HYBRID")
    do_flip  = (not opposite) or (i_flip_mode == "B_REPLACEMENT") or (i_flip_mode == "C_HYBRID")
    last_mss_time := time
    last_mss_kind := "MSS up"
    if fire_df
        last_df_time := time
        last_df_kind := "DF up"
        if i_show_df_events
            label.new(chart.point.from_index(bar_index, low - candle_range * 0.5), text="DF up", style=label.style_label_up, color=color.new(color.orange, 0), textcolor=color.black, size=size.normal)
    if do_flip
        map_direction := 1
        range_birth_bar := bar_index

if mss_bear_fired
    opposite = map_direction == 1
    fire_df  = opposite and (i_flip_mode == "A_DELIVERY_FAILURE" or i_flip_mode == "C_HYBRID")
    do_flip  = (not opposite) or (i_flip_mode == "B_REPLACEMENT") or (i_flip_mode == "C_HYBRID")
    last_mss_time := time
    last_mss_kind := "MSS dn"
    if fire_df
        last_df_time := time
        last_df_kind := "DF dn"
        if i_show_df_events
            label.new(chart.point.from_index(bar_index, high + candle_range * 0.5), text="DF dn", style=label.style_label_down, color=color.new(color.orange, 0), textcolor=color.black, size=size.normal)
    if do_flip
        map_direction := -1
        range_birth_bar := bar_index

dir_bg = map_direction == 1 ? color.new(color.green, 92) : map_direction == -1 ? color.new(color.red, 92) : na
bgcolor(i_show_direction ? dir_bg : na, title="Map Direction tint")

// =============================================================================
// Pivotal date markers (Gate 2 fixture anchors)
// =============================================================================
// Olya's 5 pivotal Gate 2 dates — labeled directly on the chart so we never
// have to ask "which bar is which date" during the session.
bar_date_int = year * 10000 + month * 100 + dayofmonth

pivotal_text = bar_date_int == 20251210 ? "Dec 10  range birth?"      : bar_date_int == 20251224 ? "Dec 24  target hit?"        : bar_date_int == 20260122 ? "Jan 22  range succession?"  : bar_date_int == 20260302 ? "Mar 2  BEARISH FLIP"        : bar_date_int == 20260303 ? "Mar 3  bearish low?"        : ""

if i_show_pivotal and pivotal_text != ""
    label.new(chart.point.from_index(bar_index, high + candle_range * 1.5), text=pivotal_text, style=label.style_label_down, color=color.new(color.blue, 0), textcolor=color.white, size=size.small)

// =============================================================================
// State-readout table (top-right corner) — current state at-a-glance
// =============================================================================
var table state_table = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 70), border_color=color.new(color.gray, 50), border_width=1)

if barstate.islast and i_show_table
    dir_str = map_direction == 1 ? "BULL up" : map_direction == -1 ? "BEAR dn" : "-"
    dir_col = map_direction == 1 ? color.lime : map_direction == -1 ? color.red : color.gray
    mss_str = last_mss_kind == "-" ? "-" : last_mss_kind + "  " + str.format("{0,date,yyyy-MM-dd}", last_mss_time)
    df_str  = last_df_kind  == "-" ? "-" : last_df_kind  + "  " + str.format("{0,date,yyyy-MM-dd}", last_df_time)

    table.cell(state_table, 0, 0, "HTF MAP V1",  bgcolor=color.new(color.navy, 30), text_color=color.white, text_size=size.normal)
    table.cell(state_table, 1, 0, "calibration", bgcolor=color.new(color.navy, 30), text_color=color.silver, text_size=size.normal)
    table.cell(state_table, 0, 1, "Date",        text_color=color.silver, text_size=size.small)
    table.cell(state_table, 1, 1, str.format("{0,date,yyyy-MM-dd}", time), text_color=color.white,  text_size=size.small)
    table.cell(state_table, 0, 2, "Direction",   text_color=color.silver, text_size=size.small)
    table.cell(state_table, 1, 2, dir_str,       text_color=dir_col,      text_size=size.small)
    table.cell(state_table, 0, 3, "Mode",        text_color=color.silver, text_size=size.small)
    table.cell(state_table, 1, 3, i_flip_mode,   text_color=color.yellow, text_size=size.small)
    table.cell(state_table, 0, 4, "Last MSS",    text_color=color.silver, text_size=size.small)
    table.cell(state_table, 1, 4, mss_str,       text_color=color.white,  text_size=size.small)
    table.cell(state_table, 0, 5, "Last DF",     text_color=color.silver, text_size=size.small)
    table.cell(state_table, 1, 5, df_str,        text_color=color.orange, text_size=size.small)
